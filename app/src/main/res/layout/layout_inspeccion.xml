<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/fondo_tarjeta"
    android:padding="12dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp">

    <!-- Titulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inspección"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Nombre inspeccion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOMBRE INSPECCIÓN"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_nombre_inspeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Inspección mensual"
        android:inputType="text"
        android:padding="8dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Descripcion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DESCRIPCIÓN"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_descripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Describe la inspección..."
        android:inputType="textMultiLine"
        android:minLines="2"
        android:gravity="top"
        android:padding="8dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Fecha -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FECHA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <CalendarView
        android:id="@+id/calendario_inspeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <!-- Repetir cada -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REPETIR CADA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <Spinner
        android:id="@+id/spinner_repetir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/opciones_repeticion"
        android:padding="8dp" />

</LinearLayout>
