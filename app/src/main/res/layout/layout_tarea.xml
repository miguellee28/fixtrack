<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/fondo_tarjeta_tarea"
    android:padding="12dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="16dp">

    <!-- Titulo + Boton eliminar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
        android:text="@string/mantenimiento"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/boton_eliminar"
            android:layout_width="28dp"
            android:layout_height="28dp"
        android:text="@string/cerrar"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Nombre tarea -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nombre_mantenimiento_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_nombre_tarea"
        android:importantForAutofill="no"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:gravity="center_vertical"
        android:hint="@string/ejemplo_mantenimiento"
        android:includeFontPadding="false"
        android:inputType="text"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Descripcion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/descripcion_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_descripcion"
        android:importantForAutofill="no"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:hint="@string/ejemplo_descripcion_mantenimiento"
        android:includeFontPadding="false"
        android:inputType="textMultiLine"
        android:gravity="center_vertical"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Fecha -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fecha_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/texto_fecha_tarea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_fecha_editable"
        android:clickable="true"
        android:contentDescription="@string/cambiar_fecha"
        app:drawableEndCompat="@drawable/ic_editar_fecha"
        android:drawablePadding="8dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:padding="10dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#6750A4"
        android:layout_marginBottom="8dp" />

    <!-- Repetir cada -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/repetir_cada_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <Spinner
        android:id="@+id/spinner_repetir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/opciones_repeticion"
        android:padding="8dp" />

</LinearLayout>
