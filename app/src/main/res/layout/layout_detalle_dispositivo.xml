<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/fondo_tarjeta_dispositivo"
    android:padding="12dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="16dp">

    <!-- Titulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/detalle_dispositivo"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/fondo_agregar_foto_area"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="10dp">

        <ImageView
            android:id="@+id/foto_dispositivo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/foto_dispositivo"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:id="@+id/texto_foto_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginBottom="6dp"
                android:contentDescription="@string/agregar_foto"
                android:src="@drawable/ic_agregar_foto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agregar_foto_dispositivo"
                android:textColor="@color/purple_500"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/toca_camara_galeria"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Nombre del dispositivo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nombre_dispositivo_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_nombre"
        android:importantForAutofill="no"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:gravity="center_vertical"
        android:hint="@string/ejemplo_nombre_dispositivo"
        android:includeFontPadding="false"
        android:inputType="text"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Categoria -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/categoria_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <Spinner
        android:id="@+id/spinner_categoria"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:entries="@array/opciones_categoria"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginBottom="8dp" />

    <!-- Marca -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/marca_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_marca"
        android:importantForAutofill="no"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:gravity="center_vertical"
        android:hint="@string/ejemplo_marca"
        android:includeFontPadding="false"
        android:inputType="text"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Modelo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/modelo_mayuscula"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_modelo"
        android:importantForAutofill="no"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:gravity="center_vertical"
        android:hint="@string/ejemplo_modelo"
        android:includeFontPadding="false"
        android:inputType="text"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp" />

</LinearLayout>
