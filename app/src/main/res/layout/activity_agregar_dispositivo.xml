<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <!-- Titulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Agregar Dispositivo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Toggle Manual / IA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/opcion_manual"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:text="Manual"
            android:background="@drawable/fondo_toggle_seleccionado"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/opcion_ia"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:text="IA"
            android:background="@drawable/fondo_toggle_no_seleccionado"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- Lista de acciones -->
    <ListView
        android:id="@+id/lista_acciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:padding="8dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="16dp" />

    <!-- Botones Agregar Tarea e Inspeccion -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/boton_agregar_tarea"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Agregar&#10;Tarea"
            android:textAllCaps="false"
            android:gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/boton_agregar_inspeccion"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Agregar&#10;Inspección"
            android:textAllCaps="false"
            android:gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- Boton Aceptar -->
    <Button
        android:id="@+id/boton_aceptar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aceptar"
        android:textAllCaps="false" />

</LinearLayout>
